{
    "name": "prularia/webshop",
    "description": "Prularia Webshop - PHP MVC Project",
    "type": "project",
    "require": {
        "php": ">=8.1",
      "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Config\\": "Config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "Tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
